#!/bin/bash
#
# stomarchy - Save and restore your Omarchy config without disrupting its opinionated design
#
# Usage: stomarchy [command] [options]
#
# Commands:
#   add       - Track a file with stomarchy
#   apply     - Apply tracked customizations to Omarchy configs
#   sync      - Sync Omarchy defaults from latest release
#   status    - Show current status of tracked files
#   help      - Show this help message
#

set -e

VERSION="0.1.0"
STOMARCHY_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/stomarchy"
OMARCHY_REPO="basecamp/omarchy"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/stomarchy"
VERSION_FILE="${STOMARCHY_DIR}/.stomarchy-omarchy-version"

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Logging functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

# Initialize directories
init_dirs() {
    mkdir -p "$STOMARCHY_DIR"
    mkdir -p "$CACHE_DIR"
}

# Get latest Omarchy release version
get_latest_release() {
    local repo="$1"
    local release_url="https://api.github.com/repos/${repo}/releases/latest"
    
    if command -v curl &> /dev/null; then
        curl -s "$release_url" | grep -oP '"tag_name": "\K(.*)(?=")'
    elif command -v wget &> /dev/null; then
        wget -qO- "$release_url" | grep -oP '"tag_name": "\K(.*)(?=")'
    else
        log_error "Neither curl nor wget found. Please install one of them."
        exit 1
    fi
}

# Convert absolute path to stomarchy-relative path
# Stomarchy root corresponds to $HOME
get_stomarchy_path() {
    local file_path="$1"
    local abs_path
    abs_path=$(realpath "$file_path" 2>/dev/null || echo "$file_path")
    
    # Strip $HOME prefix to get relative path
    local rel_path="${abs_path#"$HOME"/}"
    
    if [ "$rel_path" = "$abs_path" ]; then
        log_error "File must be under home directory: $HOME"
        exit 1
    fi
    
    echo "${STOMARCHY_DIR}/${rel_path}"
}

# Add a file to stomarchy tracking
cmd_add() {
    if [ -z "$1" ]; then
        log_error "Usage: stomarchy add <file>"
        exit 1
    fi
    
    local source_file="$1"
    
    if [ ! -f "$source_file" ]; then
        log_error "File not found: $source_file"
        exit 1
    fi
    
    init_dirs
    
    local stomarchy_path
    stomarchy_path=$(get_stomarchy_path "$source_file")
    
    # Create directory structure
    mkdir -p "$(dirname "$stomarchy_path")"
    
    # Copy file to stomarchy directory
    cp "$source_file" "$stomarchy_path"
    
    log_success "Added: $source_file"
    log_info "Tracked at: $stomarchy_path"
    log_info "Use 'stomarchy apply' to add source directives to Omarchy configs"
}

# Apply tracked customizations by appending source directives
cmd_apply() {
    log_info "Applying tracked customizations..."
    init_dirs
    
    if [ ! -d "$STOMARCHY_DIR" ]; then
        log_error "No tracked files found. Use 'stomarchy add <file>' first."
        exit 1
    fi
    
    local files_processed=0
    
    # Process each tracked file (skip dotfiles that are stomarchy internals)
    while IFS= read -r -d '' tracked_file; do
        # Get relative path from stomarchy dir
        local rel_path="${tracked_file#"$STOMARCHY_DIR"/}"
        
        # Skip stomarchy internal files (dotfiles starting with .stomarchy-)
        local filename
        filename=$(basename "$tracked_file")
        if [[ "$filename" == .stomarchy-* ]]; then
            continue
        fi
        
        # The corresponding file in home directory
        local target_file="${HOME}/${rel_path}"
        
        if [ ! -f "$target_file" ]; then
            log_warn "Target file not found, skipping: $target_file"
            continue
        fi
        
        # Determine source directive syntax based on file extension
        local source_directive
        case "${rel_path##*.}" in
            conf)
                source_directive="source = ${tracked_file}"
                ;;
            sh)
                source_directive="source \"${tracked_file}\""
                ;;
            *)
                source_directive="source ${tracked_file}"
                ;;
        esac
        
        # Add directive if not already present
        if ! grep -Fq "$tracked_file" "$target_file" 2>/dev/null; then
            {
                echo ""
                echo "# Stomarchy customizations"
                echo "$source_directive"
            } >> "$target_file"
            log_info "Added import directive to: $target_file"
            files_processed=$((files_processed + 1))
        else
            log_info "Already applied: $target_file"
        fi
    done < <(find "$STOMARCHY_DIR" -type f -print0)
    
    if [ "$files_processed" -eq 0 ]; then
        log_info "No new customizations to apply"
    else
        log_success "Applied $files_processed customization(s)"
    fi
}

# Sync Omarchy defaults from latest release
cmd_sync() {
    log_info "Syncing Omarchy defaults from latest release..."
    init_dirs
    
    local latest_version
    latest_version=$(get_latest_release "$OMARCHY_REPO")
    
    if [ -z "$latest_version" ]; then
        log_error "Failed to fetch latest Omarchy release"
        exit 1
    fi
    
    log_info "Latest Omarchy version: $latest_version"
    
    local current_version=""
    
    if [ -f "$VERSION_FILE" ]; then
        current_version=$(cat "$VERSION_FILE")
        log_info "Current tracked version: $current_version"
    fi
    
    if [ "$current_version" = "$latest_version" ]; then
        log_success "Already at latest version: $latest_version"
        return 0
    fi
    
    # Download and compare configs
    local temp_dir="${CACHE_DIR}/omarchy-${latest_version}"
    
    if [ ! -d "$temp_dir" ]; then
        log_info "Downloading Omarchy $latest_version..."
        mkdir -p "$temp_dir"
        
        local archive_url="https://github.com/${OMARCHY_REPO}/archive/refs/tags/${latest_version}.tar.gz"
        
        if command -v curl &> /dev/null; then
            curl -sL "$archive_url" | tar xz -C "$temp_dir" --strip-components=1
        elif command -v wget &> /dev/null; then
            wget -qO- "$archive_url" | tar xz -C "$temp_dir" --strip-components=1
        else
            log_error "Neither curl nor wget found."
            exit 1
        fi
    fi
    
    # Show differences against tracked files
    log_info "Changes in default configs:"
    
    local has_changes=false
    while IFS= read -r -d '' tracked_file; do
        local rel_path="${tracked_file#"$STOMARCHY_DIR"/}"
        
        # Skip stomarchy internal files
        local filename
        filename=$(basename "$tracked_file")
        if [[ "$filename" == .stomarchy-* ]]; then
            continue
        fi
        
        # Look for corresponding file in downloaded release
        local release_file="${temp_dir}/${rel_path}"
        if [ -f "$release_file" ]; then
            local diff_output
            diff_output=$(diff -u "$tracked_file" "$release_file" 2>/dev/null) || true
            if [ -n "$diff_output" ]; then
                echo "=== $rel_path ==="
                echo "$diff_output" | head -30
                echo ""
                has_changes=true
            fi
        fi
    done < <(find "$STOMARCHY_DIR" -type f -print0)
    
    if [ "$has_changes" = false ]; then
        log_info "No changes detected in tracked files"
    fi
    
    # Update version tracking
    echo "$latest_version" > "$VERSION_FILE"
    log_success "Updated version tracking to: $latest_version"
    log_info "To apply updates, reinstall Omarchy and run 'stomarchy apply'"
}

# Show status
cmd_status() {
    log_info "Stomarchy Status"
    echo ""
    
    # Check stomarchy directory
    if [ -d "$STOMARCHY_DIR" ]; then
        log_success "Stomarchy directory: $STOMARCHY_DIR"
    else
        log_warn "Stomarchy directory not found: $STOMARCHY_DIR"
    fi
    
    # Check version tracking
    echo ""
    log_info "Version Tracking:"
    if [ -f "$VERSION_FILE" ]; then
        local current_version
        current_version=$(cat "$VERSION_FILE")
        echo "  Tracked version: $current_version"
    else
        echo "  No version tracked yet"
    fi
    
    # List tracked files
    echo ""
    log_info "Tracked Files:"
    if [ -d "$STOMARCHY_DIR" ]; then
        local file_count=0
        while IFS= read -r -d '' tracked_file; do
            local filename
            filename=$(basename "$tracked_file")
            # Skip stomarchy internal files
            if [[ "$filename" == .stomarchy-* ]]; then
                continue
            fi
            
            local rel_path="${tracked_file#"$STOMARCHY_DIR"/}"
            echo "  ~/${rel_path}"
            file_count=$((file_count + 1))
        done < <(find "$STOMARCHY_DIR" -type f -print0)
        
        if [ "$file_count" -eq 0 ]; then
            echo "  (none)"
        else
            echo ""
            echo "  Total: $file_count file(s)"
        fi
    else
        echo "  (none)"
    fi
}

# Show help
cmd_help() {
    cat << EOF
stomarchy v${VERSION}
Save and restore your Omarchy config without disrupting its opinionated design

USAGE:
    stomarchy [COMMAND] [OPTIONS]

COMMANDS:
    add <file>          Track a file with stomarchy
    apply               Apply tracked customizations to Omarchy configs
    sync                Sync with latest Omarchy release and show changes
    status              Show current status and tracked files
    help                Show this help message

EXAMPLES:
    # Track a config file
    stomarchy add ~/.config/hypr/hyprland.conf

    # Apply source directives to Omarchy configs
    stomarchy apply

    # Check for Omarchy updates
    stomarchy sync

    # View status
    stomarchy status

DIRECTORY STRUCTURE:
    Files are tracked under ~/.config/stomarchy/ with the same
    directory structure as your home directory:
    
    ~/                              ~/.config/stomarchy/
    ├── .config/                    ├── .config/
    │   └── hypr/                   │   └── hypr/
    │       └── hyprland.conf       │       └── hyprland.conf
    └── .bashrc                     └── .bashrc

    Use git to version control your ~/.config/stomarchy/ directory.

DIRECTORIES:
    Config:     ${STOMARCHY_DIR}
    Cache:      ${CACHE_DIR}

For more information, visit: https://github.com/brianblakely/stomarchy
EOF
}

# Main command dispatcher
main() {
    local command="${1:-help}"
    
    case "$command" in
        add)
            shift
            cmd_add "$@"
            ;;
        apply)
            cmd_apply
            ;;
        sync)
            cmd_sync
            ;;
        status)
            cmd_status
            ;;
        help|--help|-h)
            cmd_help
            ;;
        --version|-v)
            echo "stomarchy v${VERSION}"
            ;;
        *)
            log_error "Unknown command: $command"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
